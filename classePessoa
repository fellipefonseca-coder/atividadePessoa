public class Pessoa {
    protected String nome;

    public Pessoa(String nome) {
        this.nome = nome;
    }

    public void apresentar() {
        System.out.println("Olá, meu nome é " + nome);
    }

    // Sobrecarga
    public void apresentar(String mensagem) {
        System.out.println(mensagem + " Meu nome é " + nome);
    }
}
